{
  "manifest_version": 2,
  "name": "Smart Tab Organizer",
  "version": "0.3.0",
  "description": "Automatically groups tabs by semantic similarity using local AI",
  "browser_specific_settings": {
    "gecko": {
      "id": "smart-tab-organizer@djshelfmushroom",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": ["tabs", "storage", "notifications"],
  "optional_permissions": ["<all_urls>", "http://localhost/*"],
  "content_security_policy": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';",
  "background": {
    "scripts": [
      "chrome-compat.js",
      "storage.js",
      "habits.js",
      "lib/transformers.js",
      "embedding.js",
      "background.js"
    ],
    "persistent": false
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content/toast.js"],
    "run_at": "document_idle"
  }],
  "icons": { "48": "icon-48.png", "96": "icon-96.png" },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Smart Tab Organizer",
    "default_icon": { "48": "icon-48.png", "96": "icon-96.png" }
  }
}
